# Copy this file to `.env` and fill in real values.
# Never commit your real `.env`.

# --- OpenVPN management interface (required) ---
OPENVPN_HOST=10.0.0.5
OPENVPN_PORT=5555
# OPENVPN_PASSWORD=

# --- Display ---
SITE_NAME=My VPN
REFRESH_SECONDS=10
TIMEZONE=UTC
LOG_LEVEL=INFO

# --- Built-in authentication (set to enable; leave empty to disable) ---
AUTH_USERNAME=admin
# Generate with: python -m ovispect.hash_password
AUTH_PASSWORD_HASH=
# Generate with: openssl rand -hex 32   (must be >= 32 chars)
SESSION_SECRET=
SESSION_LIFETIME_SECONDS=86400

# Set to `false` ONLY for local plaintext testing without TLS.
# In production keep this as `true` and put ovispect behind HTTPS.
SESSION_COOKIE_SECURE=true

# --- GeoIP (optional) ---
# Path to a db-ip.com Lite Country CSV (.csv or .csv.gz). The Docker
# image bundles a fresh copy at the default location below; set this to
# an empty value or a non-existent path to disable the country flag
# column entirely.
GEOIP_DATABASE_PATH=/opt/geo/dbip-country-lite.csv.gz

# --- Webhooks (optional, fire-and-forget) ---
# Empty WEBHOOK_URL disables the entire feature. When set, ovispect runs
# a background task that polls the management interface every
# WEBHOOK_POLL_SECONDS, diffs snapshots, and POSTs an event for every
# connect/disconnect.
WEBHOOK_URL=
# generic | slack | discord | gotify
WEBHOOK_FORMAT=generic
# Optional HMAC-SHA256 secret. When set, the body is signed and the
# digest is sent as `X-Ovispect-Signature: sha256=<hex>`. Most useful
# with WEBHOOK_FORMAT=generic.
WEBHOOK_SECRET=
WEBHOOK_TIMEOUT_SECONDS=5
WEBHOOK_POLL_SECONDS=10
WEBHOOK_MAX_RETRIES=3
# Comma-separated subset of: connect,disconnect
WEBHOOK_EVENTS=connect,disconnect
